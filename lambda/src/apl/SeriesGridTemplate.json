{
  "type": "APL",
  "version": "2024.2",
  "theme": "dark",
  "mainTemplate": {
    "parameters": ["payload"],
    "items": [
      {
        "type": "Container",
        "width": "100vw",
        "height": "100vh",
        "direction": "column",
        "items": [
          {
            "type": "Container",
            "width": "100%",
            "height": "60dp",
            "alignItems": "center",
            "justifyContent": "center",
            "items": [
              {
                "type": "Text",
                "text": "Hörspiel Player",
                "fontSize": "28dp",
                "fontWeight": "bold",
                "color": "#FFFFFF"
              }
            ]
          },
          {
            "when": "${payload.resumeData != null}",
            "type": "TouchWrapper",
            "width": "100%",
            "onPress": {
              "type": "SendEvent",
              "arguments": ["ResumeDevice", "${payload.resumeData.episodeId}"]
            },
            "item": {
              "type": "Container",
              "width": "100%",
              "direction": "row",
              "alignItems": "center",
              "paddingLeft": "24dp",
              "paddingRight": "24dp",
              "paddingTop": "8dp",
              "paddingBottom": "8dp",
              "items": [
                {
                  "type": "Image",
                  "source": "${payload.resumeData.coverUrl}",
                  "width": "56dp",
                  "height": "56dp",
                  "borderRadius": "8dp",
                  "scale": "best-fill"
                },
                {
                  "type": "Container",
                  "paddingLeft": "16dp",
                  "grow": 1,
                  "items": [
                    {
                      "type": "Text",
                      "text": "▶ Fortsetzen",
                      "fontSize": "18dp",
                      "fontWeight": "bold",
                      "color": "#1DB954"
                    },
                    {
                      "type": "Text",
                      "text": "${payload.resumeData.seriesTitle} — ${payload.resumeData.title}",
                      "fontSize": "16dp",
                      "color": "#B3B3B3",
                      "maxLines": 1
                    }
                  ]
                }
              ]
            }
          },
          {
            "type": "Container",
            "width": "100%",
            "grow": 1,
            "paddingLeft": "24dp",
            "paddingRight": "24dp",
            "items": [
              {
                "type": "GridSequence",
                "width": "100%",
                "height": "100%",
                "childWidths": ["33%", "33%", "33%"],
                "childHeight": "auto",
                "scrollDirection": "vertical",
                "data": "${payload.seriesData.series}",
                "items": [
                  {
                    "type": "TouchWrapper",
                    "onPress": {
                      "type": "SendEvent",
                      "arguments": ["SelectSeries", "${data.id}"]
                    },
                    "item": {
                      "type": "Container",
                      "alignItems": "center",
                      "paddingBottom": "16dp",
                      "paddingTop": "8dp",
                      "items": [
                        {
                          "type": "Image",
                          "source": "${data.coverUrl}",
                          "width": "200dp",
                          "height": "200dp",
                          "borderRadius": "12dp",
                          "scale": "best-fill"
                        },
                        {
                          "type": "Text",
                          "text": "${data.title}",
                          "fontSize": "18dp",
                          "color": "#FFFFFF",
                          "textAlign": "center",
                          "paddingTop": "8dp",
                          "maxLines": 2
                        }
                      ]
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
